generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model location {
  id         Int         @id @default(autoincrement())
  code       String      @unique @db.VarChar(10)
  province   String      @db.VarChar(100)
  latitude   Decimal?    @db.Decimal(9, 6)
  longitude  Decimal?    @db.Decimal(9, 6)
  created_at DateTime    @default(now()) @db.Timestamptz(6)
  pm_actual  pm_actual[]
}

model pm_actual {
  id            Int             @id @default(autoincrement())
  location_id   Int
  date          DateTime        @db.Date
  pm            Decimal?        @db.Decimal(8, 4)
  temp          Decimal?        @db.Decimal(5, 2)
  dew_point     Decimal?        @db.Decimal(5, 2)
  humidity      Int?            @db.SmallInt
  pressure      Decimal?        @db.Decimal(7, 2)
  wind_speed    Decimal?        @db.Decimal(5, 2)
  precipitation Decimal?        @db.Decimal(6, 2)
  wind_dir_sin  Decimal?        @db.Decimal(18, 16)
  wind_dir_cos  Decimal?        @db.Decimal(18, 16)
  month         Int?            @db.SmallInt
  month_sin     Decimal?        @db.Decimal(18, 16)
  month_cos     Decimal?        @db.Decimal(18, 16)
  fetched_at    DateTime        @default(now()) @db.Timestamptz(6)
  location      location        @relation(fields: [location_id], references: [id], onUpdate: NoAction)
  pm_prediction pm_prediction[]

  @@unique([location_id, date], map: "uq_pm_actual_location_date")
  @@index([date(sort: Desc)], map: "idx_pm_actual_date")
  @@index([location_id], map: "idx_pm_actual_location_id")
}

model pm_prediction {
  id            Int       @id @default(autoincrement())
  pm_actual_id  Int
  predicted_for DateTime  @db.Date
  pm_predicted  Decimal?  @db.Decimal(8, 4)
  temp          Decimal?  @db.Decimal(5, 2)
  dew_point     Decimal?  @db.Decimal(5, 2)
  humidity      Int?      @db.SmallInt
  pressure      Decimal?  @db.Decimal(7, 2)
  wind_speed    Decimal?  @db.Decimal(5, 2)
  precipitation Decimal?  @db.Decimal(6, 2)
  wind_dir_sin  Decimal?  @db.Decimal(18, 16)
  wind_dir_cos  Decimal?  @db.Decimal(18, 16)
  month         Int?      @db.SmallInt
  month_sin     Decimal?  @db.Decimal(18, 16)
  month_cos     Decimal?  @db.Decimal(18, 16)
  predicted_at  DateTime  @default(now()) @db.Timestamptz(6)
  pm_actual     pm_actual @relation(fields: [pm_actual_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([pm_actual_id, predicted_for], map: "uq_pm_prediction_actual_date")
  @@index([pm_actual_id], map: "idx_pm_prediction_actual_id")
  @@index([predicted_for], map: "idx_pm_prediction_for")
}
